{
    "$schema": "https://railway.app/railway.schema.json",
"build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm run build"
    },
    "deploy": {
      "startCommand": "npm run start & node discord-bot.js",
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
    }
  }